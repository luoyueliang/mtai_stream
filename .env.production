# 运行环境
PORT=3100
NODE_ENV=production

# Redis（与 mtai_backend 共用同一 Redis 实例）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Laravel mtai_backend 内网地址
LARAVEL_BASE_URL=http://127.0.0.1:80
LARAVEL_HOST=ai.mtedu.com

# 内部通信密钥（与 mtai_backend .env 的 STREAM_SERVICE_SECRET 保持一致）
INTERNAL_TOKEN=

# CORS 允许的域名
CORS_ORIGIN=https://ai.mtedu.com

# 单个任务的最长等待超时（毫秒）
TASK_TIMEOUT_MS=120000
