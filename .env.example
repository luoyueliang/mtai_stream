# 运行环境

PORT=3100
NODE_ENV=production

# Redis（与 mtai_backend 共用同一 Redis 实例）
REDIS_URL=redis://127.0.0.1:6379
REDIS_DB=3

# Laravel mtai_backend 内网地址（Node.js 与 Laravel 同机时走 127.0.0.1）
LARAVEL_BASE_URL=http://127.0.0.1:80

# 内部通信密钥（与 mtai_backend .env 的 STREAM_SERVICE_SECRET 保持一致）
INTERNAL_TOKEN=

# 单个任务的最长等待超时（毫秒），超出后推送 error 事件并关闭 SSE 流
TASK_TIMEOUT_MS=120000
